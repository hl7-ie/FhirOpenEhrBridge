{
  "name": "@hl7-ie/fhir-openehr-bridge",
  "version": "0.1.0",
  "description": "Bidirectional FHIR <-> openEHR translation engine (Node.js/TypeScript port)",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/hl7-ie/FhirOpenEhrBridge" },
  "main": "dist/index.js",
